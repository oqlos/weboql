# WebOQL Service Configuration Example
# Copy this file to .env and adjust values as needed

# Server Configuration
WEB_PORT=8203
WEB_HOST=0.0.0.0

# Scenarios Directory
SCENARIOS_DIR=/home/tom/github/oqlos/oqlos/oqlos/scenarios

# Hardware Mode (mock | real)
HARDWARE_MODE=mock

# Logging (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# CORS Settings (comma-separated origins or * for all)
CORS_ORIGINS=*

# Service Metadata
SERVICE_NAME=weboql
SERVICE_VERSION=0.1.0
